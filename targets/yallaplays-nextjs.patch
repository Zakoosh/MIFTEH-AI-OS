+function slugHash(slug: string): number {
+  let h = 5381
+  for (let i = 0; i < slug.length; i++) h = (h * 33) ^ slug.charCodeAt(i)
+  return Math.abs(h >>> 0)
+}
+
+function getStarRating(slug: string): number {
+  return Math.round((3.5 + (slugHash(slug) % 16) * 0.1) * 10) / 10
+}
+
+function getLiveCount(slug: string): string {
+  const n = 80 + (slugHash(slug) % 420)
+  return n >= 1000 ? `${(n / 1000).toFixed(1)}K` : `${n}`
+}
+
+function getPlayCount(slug: string): string {
+  const buckets = ['2.1K', '5.4K', '8.3K', '12K', '18K', '24K', '31K', '45K', '67K', '89K', '100K+']
+  return buckets[slugHash(slug) % buckets.length]
+}
+
+function StarRating({ rating, size = 'sm' }: { rating: number; size?: 'sm' | 'md' }) {
+  const stars = []
+  for (let i = 1; i <= 5; i++) {
+    if (i <= Math.floor(rating)) stars.push('full')
+    else if (i - rating < 1) stars.push('half')
+    else stars.push('empty')
+  }
+  const cls = size === 'md' ? 'text-base' : 'text-xs'
+  return (
+    <span className={`inline-flex items-center gap-0.5 ${cls}`}>
+      {stars.map((t, i) => (
+        <span key={i} className={t === 'empty' ? 'text-white/20' : 'text-amber-400'}>
+          {t === 'full' ? '★' : t === 'half' ? '⯨' : '☆'}
+        </span>
+      ))}
+    </span>
+  )
+}
