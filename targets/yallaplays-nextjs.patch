@@ -0,0 +1,42 @@
+'use client'
+
+import { useState, useEffect } from 'react'
+import { AdSenseUnit } from '@/components/adsense/AdSense'
+
+const ANCHOR_SLOT = '7788990011'
+
+export default function MobileAnchorAd() {
+  const [dismissed, setDismissed] = useState(false)
+  const [visible, setVisible] = useState(false)
+
+  useEffect(() => {
+    const timer = setTimeout(() => setVisible(true), 2000)
+    return () => clearTimeout(timer)
+  }, [])
+
+  if (dismissed || !visible) return null
+
+  return (
+    <div
+      className="mobile-anchor-ad"
+      role="complementary"
+      aria-label="Advertisement"
+    >
+      <button
+        onClick={() => setDismissed(true)}
+        className="mobile-anchor-close"
+        aria-label="Close advertisement"
+      >
+        ✕
+      </button>
+      <div style={{ minHeight: 60, minWidth: 320 }}>
+        <AdSenseUnit
+          slot={ANCHOR_SLOT}
+          format="auto"
+          responsive
+          style={{ display: 'block', minHeight: 60 }}
+        />
+      </div>
+    </div>
+  )
+}
