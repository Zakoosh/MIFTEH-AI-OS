# ==========================================
# AI Provider Keys
# ==========================================
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ==========================================
# GitHub — Personal Access Token
# ==========================================
GITHUB_TOKEN=your-github-personal-access-token

# ==========================================
# Admin Authentication — NEVER hardcode real values here
# Use .env.local (gitignored) for actual credentials
# ==========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SECRET=change-this-to-a-random-64-char-string-in-production

# ==========================================
# MIFTEH OS Domain
# ==========================================
MIFTEH_OS_URL=https://miftehos.com
MIFTEH_API_URL=https://api.miftehos.com

# ==========================================
# GitHub Repository Targets
# ==========================================
GITHUB_REPO_YALLAPLAYS=YourOrg/yallaplays
GITHUB_REPO_FIONERA=YourOrg/fionera
GITHUB_REPO_MIFTEH=YourOrg/mifteh

# ==========================================
# Market Data
# ==========================================
VITE_ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
VITE_TWELVE_DATA_API_KEY=your-twelve-data-key
VITE_TWELVE_DATA_BASE_URL=https://api.twelvedata.com
